# Copy to .env and fill from Supabase dashboard → Project Settings → API.
# The anon key is public-safe (RLS is the boundary) but keep .env out of git anyway.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# AI custom diet plan (docs/n8n-diet-setup.md). The webhook URL is the
# Production URL of the imported n8n workflow. The secret is a shared string
# the workflow checks on the incoming request; set the SAME value in n8n.
# Leave blank until n8n is set up — the questionnaire still records the request.
EXPO_PUBLIC_N8N_DIET_WEBHOOK_URL=
EXPO_PUBLIC_N8N_DIET_SECRET=
