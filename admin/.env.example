# Copy to .env.local and fill in.

# Same project + anon key as the mobile app (RLS is the boundary;
# admin writes are unlocked by admin_users membership, not by a stronger key).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Bunny — SERVER-ONLY (no NEXT_PUBLIC_ prefix; never sent to the browser).
# Leave empty until the Bunny account exists: the panel then runs in
# paste-URL mode and everything else still works.
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOST=            # e.g. vz-xxxxxxx-xxx.b-cdn.net
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_CDN_HOST=           # pull zone host, e.g. fithindu-media.b-cdn.net
